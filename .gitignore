## Swift Package Manager local caches.
## NOTE: the SHARED Package.resolved
##   (Offline_Mission_Control.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved)
## IS committed — it pins the Meta SDK version. Do NOT ignore it.
.build/
.swiftpm/xcode/package.xcworkspace/xcuserdata/

# ===================== Meta DAT SDK clone ======================
# Local reference clone of github.com/facebook/meta-wearables-dat-ios (~119 MB).
# The app consumes it via Swift Package Manager (pinned in Package.resolved),
# so the clone is NOT part of the repo — collaborators fetch the package in Xcode.
meta-wearables-dat-ios/

# ================== Python (model conversion) ==================
.venv-convert/
tools/_build/
__pycache__/
*.pyc
*.pyo

# ============ Generated Core ML models (large) ============
# Only the small default YOLOv8n is committed. The larger models exceed GitHub's file-size
# limit (100 MB) — generate them locally with `tools/convert_models.py`.
Offline_Mission_Control/Offline_Mission_Control/Resources/*.mlpackage/
!Offline_Mission_Control/Offline_Mission_Control/Resources/YOLOv8n.mlpackage/

